{
  "name": "@versedhand/sms-mcp",
  "version": "1.0.1",
  "description": "MCP server for SMS send/receive via phone gateway + LifeDB",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "sms-mcp": "dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/*.test.*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/versedhand/sms-mcp.git"
  },
  "keywords": [
    "mcp",
    "sms",
    "android",
    "model-context-protocol"
  ],
  "author": "Isaac Robinson",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@versedhand/common": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.3.0",
    "vitest": "^3.0.0"
  }
}
